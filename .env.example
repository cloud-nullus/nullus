# Server
NULLUS_SERVER_PORT=8090
NULLUS_SERVER_MODE=development

# Database
NULLUS_DB_HOST=localhost
NULLUS_DB_PORT=5433
NULLUS_DB_NAME=nullus
NULLUS_DB_USER=nullus
NULLUS_DB_PASSWORD=nullus_dev
NULLUS_DB_SSLMODE=disable

# Auth
NULLUS_AUTH_MODE=session
NULLUS_AUTH_SESSION_SECRET=dev-secret-change-in-production

# Encryption (must be exactly 32 bytes)
ENCRYPTION_KEY=nullus-dev-key-32bytes-padding!!

# Secret manager / token injection (optional)
NULLUS_ENV=dev
# OPENBAO_ADDR=http://openbao.nullus-devsecops-stack.internal
# OPENBAO_TOKEN=<openbao-root-or-service-token>
# NULLUS_GITHUB_TOKEN=<github-pat-used-for-github-argocd>

# MinIO
NULLUS_MINIO_ENDPOINT=localhost:9000
NULLUS_MINIO_ACCESS_KEY=nullus
NULLUS_MINIO_SECRET_KEY=nullus_dev
